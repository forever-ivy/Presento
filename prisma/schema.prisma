generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id               String               @id
  name             String
  category         String
  ownerScope       String
  teammateScope    String
  createdAt        DateTime
  updatedAt        DateTime             @updatedAt
  members          ProjectMember[]
  files            FileAsset[]
  codeRepositorySources CodeRepositorySource[]
  processingTasks  ProcessingTask[]
  artifacts        Artifact[]
  sources          ProjectSource[]
  slideDecks       SlideDeck[]
  slides           Slide[]
  knowledgeChunks  KnowledgeChunk[]
  knowledgeNodes   KnowledgeNode[]
  knowledgeEdges   KnowledgeEdge[]
  riskQuestions    RiskQuestion[]
  practiceTurns    DefensePracticeTurn[]
  trainingSessions TrainingSession[]
  trainingTurns    TrainingTurn[]
  realtimeSessions RealtimeSession[]
  realtimeEvents   RealtimeEvent[]
  voiceCaptures    VoiceCapture[]
  weaknesses       Weakness[]
  deepDives        DeepDive[]
  reviewReports    ReviewReport[]
  contentExports   ContentExport[]
  pcgConnections   PcgMockConnection[]
  jobRuns          JobRun[]
  skillFeedbacks   SkillFeedback[]
  agentSkills      AgentSkill[]
  skillPacks       SkillPack[]
  projectSkillPacks ProjectSkillPack[]
  skillInvocations SkillInvocation[]
  skillRecommendationLogs SkillRecommendationLog[]
  fileExplanationSessions FileExplanationSession[]
  fileExplanationTurns    FileExplanationTurn[]
}

model ProjectMember {
  id        String   @id
  projectId String
  name      String
  role      String?
  scope     String
  isOwner   Boolean  @default(false)
  createdAt DateTime
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model SkillInvocation {
  id                    String          @id
  projectId             String
  skillName             String
  skillVersion          String
  trigger               String
  resolvedBy            String
  status                String
  input                 Json
  output                Json
  error                 String?
  traceId               String?
  langfuseTraceId       String?
  langfuseObservationId String?
  usedFallback          Boolean
  retrievalSummary      Json?
  toolCalls             Json
  outputSummary         Json?
  feedbackStatus        String          @default("none")
  startedAt             DateTime
  completedAt           DateTime
  durationMs            Int
  project               Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feedbacks             SkillFeedback[]

  @@index([projectId, startedAt])
  @@index([skillName, status])
  @@index([langfuseTraceId])
}

model SkillFeedback {
  id           String          @id
  projectId    String
  invocationId String
  rating       String
  comment      String?
  createdAt    DateTime
  syncedAt     DateTime?
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invocation   SkillInvocation @relation(fields: [invocationId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([invocationId])
}

model AgentSkill {
  id          String   @id
  projectId   String?
  scope       String
  name        String
  description String
  manifest    Json
  enabled     Boolean
  createdAt   DateTime
  updatedAt   DateTime @updatedAt
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([scope, enabled])
}

model SkillPack {
  id          String   @id
  projectId   String?
  name        String
  description String
  metadata    Json
  createdAt   DateTime
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectSkillPack {
  id        String   @id
  projectId String
  packId    String
  enabled   Boolean
  source    String
  reason    String?
  createdAt DateTime
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, packId])
  @@index([projectId, enabled])
}

model SkillRecommendationLog {
  id               String   @id
  projectId        String
  requestedSkillId String?
  resolvedSkillId  String?
  mode             String
  event            String
  reason           String
  context          Json
  accepted         Boolean?
  createdAt        DateTime
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model DefensePracticeTurn {
  id             String   @id
  projectId      String
  slideIndex     Int
  slideTitle     String
  teacherRole    String
  userAnswer     String
  aiMessage      String
  score          Int
  strengths      Json
  risks          Json
  improvedAnswer String
  followUps      Json
  citations      Json
  createdAt      DateTime
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model FileAsset {
  id           String           @id
  projectId    String
  name         String
  size         Int
  mimeType     String?
  kind         String
  status       String
  source       String
  storedName   String?
  storagePath  String?
  storageKey   String?
  uploadedAt   DateTime?
  uploadStatus String?
  addedAt      DateTime
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sources      ProjectSource[]
  slideDecks   SlideDeck[]
  slides       Slide[]
  tasks        ProcessingTask[]
  artifacts    Artifact[]
  explanationSessions FileExplanationSession[]
  codeRepositories CodeRepositorySource[]

  @@index([projectId])
  @@index([kind])
}

model CodeRepositorySource {
  id              String   @id
  projectId       String
  fileId          String   @unique
  provider        String
  owner           String
  repo            String
  url             String
  visibility      String
  status          String
  parser          String
  defaultBranch   String?
  latestCommitSha String?
  metadata        Json
  createdAt       DateTime
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file            FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model ProjectSource {
  id         String    @id
  projectId  String
  fileId     String
  kind       String
  title      String
  summary    String
  sourcePath String?
  metadata   Json
  createdAt  DateTime
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file       FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([fileId])
}

model SlideDeck {
  id        String    @id
  projectId String
  fileId    String
  title     String
  pageCount Int
  metadata  Json
  createdAt DateTime
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file      FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)
  slides    Slide[]

  @@index([projectId])
  @@index([fileId])
}

model Slide {
  id            String     @id
  deckId        String
  projectId     String
  fileId        String?
  page          Int
  title         String
  extractedText String?
  imagePath     String?
  thumbnailPath String?
  metadata      Json
  createdAt     DateTime
  deck          SlideDeck  @relation(fields: [deckId], references: [id], onDelete: Cascade)
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file          FileAsset? @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([projectId, page])
  @@index([deckId])
}

model ProcessingTask {
  id          String    @id
  projectId   String
  fileId      String
  fileName    String
  kind        String
  title       String
  engine      String
  status      String
  progress    Int
  createdAt   DateTime
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  artifactId  String?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file        FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([fileId])
}

model Artifact {
  id           String    @id
  projectId    String
  taskId       String
  fileId       String
  fileName     String
  kind         String
  title        String
  summary      String
  previewLines Json
  sourcePath   String?
  createdAt    DateTime
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file         FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([taskId])
  @@index([fileId])
}

model KnowledgeNode {
  id        String   @id
  projectId String
  kind      String
  title     String
  summary   String
  tone      String
  sourceId  String?
  metadata  Json
  createdAt DateTime
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([kind])
}

model KnowledgeEdge {
  id         String   @id
  projectId  String
  fromNodeId String
  toNodeId   String
  kind       String
  label      String?
  createdAt  DateTime
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([fromNodeId])
  @@index([toNodeId])
}

model RiskQuestion {
  id              String   @id
  projectId       String
  slideId         String?
  knowledgeNodeId String?
  question        String
  answerFramework String?
  citations       Json
  riskLevel       String
  createdAt       DateTime
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([slideId])
  @@index([knowledgeNodeId])
}

model TrainingSession {
  id                     String   @id
  projectId              String
  title                  String
  teacherRole            String
  difficulty             String
  currentSlideId         String?
  currentKnowledgeNodeId String?
  status                 String
  voiceState             String
  hintCount              Int      @default(0)
  followUpCount          Int      @default(0)
  detectedWeaknesses     Json
  lastRetrievedSources   Json
  shouldFinish           Boolean  @default(false)
  startedAt              DateTime
  finishedAt             DateTime?
  createdAt              DateTime
  updatedAt              DateTime @updatedAt
  project                Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  turns                  TrainingTurn[]
  realtimeSessions       RealtimeSession[]
  realtimeEvents         RealtimeEvent[]
  voiceCaptures          VoiceCapture[]
  weaknesses             Weakness[]
  reviews                ReviewReport[]

  @@index([projectId, createdAt])
  @@index([status, voiceState])
}

model TrainingTurn {
  id              String          @id
  sessionId       String
  projectId       String
  realtimeSessionId String?
  turnIndex       Int?
  slideId         String?
  slideIndex      Int?
  slideTitle      String?
  knowledgeNodeId String?
  teacherRole     String
  userAnswer      String
  aiMessage       String
  inputTranscript String?
  assistantTranscript String?
  providerResponseId String?
  providerTraceId String?
  latencyMs       Int?
  mode            String         @default("realtime")
  score           Int?
  strengths       Json
  risks           Json
  improvedAnswer  String?
  followUps       Json
  citations       Json
  retrievedSourceIds Json
  speech          Json
  createdAt       DateTime
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session         TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  realtimeSession RealtimeSession? @relation(fields: [realtimeSessionId], references: [id], onDelete: SetNull)
  realtimeEvents  RealtimeEvent[]

  @@index([projectId, createdAt])
  @@index([sessionId, createdAt])
  @@index([realtimeSessionId, createdAt])
}

model RealtimeSession {
  id                     String   @id
  projectId              String
  trainingSessionId      String
  provider               String
  providerSessionId      String?
  status                 String
  currentSlideId         String?
  currentKnowledgeNodeId String?
  teacherRole            String
  difficulty             String
  contextSnapshot        Json
  clientTokenHash        String
  tokenExpiresAt         DateTime
  startedAt              DateTime?
  endedAt                DateTime?
  createdAt              DateTime
  updatedAt              DateTime @updatedAt
  project                Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  trainingSession        TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  turns                  TrainingTurn[]
  events                 RealtimeEvent[]

  @@index([projectId, createdAt])
  @@index([trainingSessionId, createdAt])
  @@index([trainingSessionId, status])
  @@index([clientTokenHash, tokenExpiresAt])
}

model RealtimeEvent {
  id                String   @id
  projectId         String
  trainingSessionId String
  realtimeSessionId String
  turnId            String?
  sequence          Int
  source            String
  eventType         String
  payload           Json
  createdAt         DateTime
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  trainingSession   TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  realtimeSession   RealtimeSession @relation(fields: [realtimeSessionId], references: [id], onDelete: Cascade)
  turn              TrainingTurn? @relation(fields: [turnId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([trainingSessionId, createdAt])
  @@index([realtimeSessionId, sequence])
  @@index([turnId])
}

model VoiceCapture {
  id             String          @id
  sessionId      String
  projectId      String
  turnId         String?
  filePath       String
  mimeType       String
  durationMs     Int?
  transcriptText String?
  state          String
  metadata       Json
  createdAt      DateTime
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session        TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([sessionId, createdAt])
}

model Weakness {
  id             String           @id
  projectId      String
  sessionId      String?
  trainingTurnId String?
  title          String
  reason         String
  status         String
  citations      Json
  createdAt      DateTime
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session        TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([sessionId])
}

model DeepDive {
  id         String   @id
  projectId  String
  weaknessId String?
  title      String
  summary    String
  checklist  Json
  citations  Json
  createdAt  DateTime
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([weaknessId])
}

model ReviewReport {
  id           String          @id
  projectId    String
  sessionId    String
  summary      String
  averageScore Int
  scoreLabel   String
  clarityScore Int
  evidenceScore Int
  pressureScore Int
  strengths    Json
  weaknesses   Json
  betterAnswers Json
  nextActions  Json
  recommendedSkills Json
  citations    Json
  createdAt    DateTime
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session      TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([sessionId])
}

model ContentExport {
  id        String   @id
  projectId String
  reviewId  String?
  kind      String
  title     String
  content   Json
  status    String
  createdAt DateTime
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([kind, status])
}

model PcgMockConnection {
  id        String   @id
  projectId String
  channel   String
  status    String
  metadata  Json
  createdAt DateTime
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([channel, status])
}

model JobRun {
  id          String   @id
  projectId   String
  kind        String
  status      String
  payload     Json
  error       String?
  result      Json?
  createdAt   DateTime
  updatedAt   DateTime
  startedAt   DateTime?
  completedAt DateTime?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([status, kind])
}

model KnowledgeChunk {
  id            String                  @id
  projectId     String
  artifactId    String?
  fileId        String?
  sourceId      String?
  chunkKind     String?
  page          Int?
  slide         Int?
  sheet         String?
  codePath      String?
  lineStart     Int?
  lineEnd       Int?
  content       String
  source        String
  metadata      Json
  retrievalText String?
  fts           Unsupported("tsvector")?
  embedding     Unsupported("vector(1536)")?
  embeddingV2   Unsupported("vector(384)")?
  createdAt     DateTime                @default(now())
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([artifactId])
  @@index([fileId])
  @@index([sourceId])
  @@index([chunkKind])
  @@index([slide])
  @@index([page])
  @@index([codePath])
}

model FileExplanationSession {
  id        String   @id
  projectId String
  nodeId    String
  fileId    String
  sourceId  String?
  mode      String
  status    String
  summary   String
  outline   Json
  citations Json
  metadata  Json
  createdAt DateTime
  updatedAt DateTime
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file      FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)
  turns     FileExplanationTurn[]

  @@index([projectId, createdAt])
  @@index([fileId, mode])
  @@index([nodeId])
}

model FileExplanationTurn {
  id        String   @id
  sessionId String
  projectId String
  role      String
  content   String
  citations Json
  metadata  Json
  createdAt DateTime
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session   FileExplanationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([sessionId, createdAt])
}
